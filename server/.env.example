# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://mortgage_user:password@localhost:5432/mortgage_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mortgage_db
DATABASE_USER=mortgage_user
DATABASE_PASSWORD=password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Mortgage data provider
# Options: mock, moneyfacts, defaqto
MORTGAGE_DATA_PROVIDER=mock

# Optional: real API keys when ready
# MONEYFACTS_API_KEY=
# MONEYFACTS_API_SECRET=
